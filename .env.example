APP_NAME="Campus Lost Found"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
LARAVEL_APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lostfound
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="Campus Lost Found"

TELEGRAM_BOT_TOKEN=
LARAVEL_BOT_SECRET=
MATCH_CONFIDENCE_THRESHOLD=0.80

# Google Cloud Vision API key — used by VisionService to tag found-item photos with LABEL_DETECTION.
# Obtain from Google Cloud Console → APIs & Services → Credentials.
# If left empty, VisionService falls back to MockCloudVisionService (random tags).
GOOGLE_VISION_API_KEY=

# Public base URL used by VisionService to build image URLs sent to the Vision API.
# Set this to the public-facing domain/IP of your VPS (e.g. http://123.45.67.89:8000).
# Must differ from APP_URL in containerised deployments where APP_URL resolves to localhost.
STORAGE_PUBLIC_URL=

# Docker Swarm service name for the Laravel app (used by deploy.sh to mount campus-lf-storage).
# Find this in Dokploy → your Laravel service → Settings → Service Name.
DOKPLOY_SERVICE_NAME=
